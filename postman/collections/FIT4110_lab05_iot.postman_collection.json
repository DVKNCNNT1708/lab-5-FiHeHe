{
  "info": {
    "name": "FIT4110 Lab 05 – IoT Ingestion API",
    "description": "Postman collection kiểm thử API trong Docker Compose stack (Lab 05).\nBaseUrl: http://localhost:8000\nAuth: Bearer {{authToken}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 – Health Check",
      "item": [
        {
          "name": "GET /health – expect 200 ok",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has status ok', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});",
                  "pm.test('Response has service field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.service).to.be.a('string');",
                  "});",
                  "pm.test('Response has version field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.version).to.be.a('string');",
                  "});",
                  "pm.test('ai_status field present', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('ai_status');",
                  "});",
                  "pm.test('db_status field present', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('db_status');",
                  "});",
                  "// Lưu reading_id để dùng ở test sau",
                  "pm.environment.set('lastReadingId', '');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "02 – Create Reading",
      "item": [
        {
          "name": "POST /readings – 201 Created (temperature normal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has reading_id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.reading_id).to.be.a('string');",
                  "    pm.environment.set('lastReadingId', json.reading_id);",
                  "});",
                  "pm.test('accepted is true', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.accepted).to.be.true;",
                  "});",
                  "pm.test('device_id matches', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.device_id).to.eql('ESP32-LAB-A01');",
                  "});",
                  "pm.test('metric matches', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.metric).to.eql('temperature');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          }
        },
        {
          "name": "POST /readings – 201 Created (smoke high – anomaly)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('reading_id present', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.reading_id).to.be.a('string');",
                  "});",
                  "pm.test('accepted is true', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.accepted).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"SMOKE-LAB-B02\",\n  \"metric\": \"smoke\",\n  \"value\": 15.0,\n  \"unit\": \"ppm\",\n  \"timestamp\": \"2026-05-13T09:00:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          }
        },
        {
          "name": "POST /readings – 401 Unauthorized (no token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Content-Type is problem+json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('problem+json');",
                  "});",
                  "pm.test('Response has title field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.title).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          }
        },
        {
          "name": "POST /readings – 401 Unauthorized (wrong token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer wrong-token-xyz" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          }
        },
        {
          "name": "POST /readings – 422 Validation Error (value out of range)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 422', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "pm.test('Response has detail field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.detail).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 999,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          }
        }
      ]
    },
    {
      "name": "03 – Get Readings",
      "item": [
        {
          "name": "GET /readings/latest – 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has items array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "});",
                  "pm.test('items is not empty', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items.length).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/readings/latest"
          }
        },
        {
          "name": "GET /readings/latest – filter by device_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has items array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/readings/latest?device_id=ESP32-LAB-A01&limit=5"
          }
        },
        {
          "name": "GET /readings/{reading_id} – 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('reading_id matches', function () {",
                  "    var json = pm.response.json();",
                  "    var expectedId = pm.environment.get('lastReadingId');",
                  "    pm.expect(json.reading_id).to.eql(expectedId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/readings/{{lastReadingId}}"
          }
        },
        {
          "name": "GET /readings/{reading_id} – 404 Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Response has title field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.title).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/readings/R-NOTEXIST-9999"
          }
        }
      ]
    }
  ]
}
