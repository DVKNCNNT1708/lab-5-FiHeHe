# syntax=docker/dockerfile:1.7

FROM python:3.11-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /build

# Tạo virtualenv riêng
RUN python -m venv /opt/venv

# Cài dependencies cho AI service
COPY src/ai_service/requirements.txt .
RUN /opt/venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt


FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PATH="/opt/venv/bin:$PATH"

# Biến runtime mặc định
ENV AI_SERVICE_NAME=ai-service
ENV AI_SERVICE_VERSION=0.1.0
ENV AI_HOST=0.0.0.0
ENV AI_PORT=9000

WORKDIR /service

# Tạo user non-root
RUN addgroup --system aigroup \
    && adduser --system --ingroup aigroup --home /service aiuser

COPY --from=builder /opt/venv /opt/venv
COPY src/ai_service/main.py ./main.py

# Cấp quyền
RUN chown -R aiuser:aigroup /service

USER aiuser

EXPOSE 9000

# Healthcheck cho AI service
HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:9000/health', timeout=3).read()" || exit 1

CMD ["python", "-c", "import uvicorn; import os; uvicorn.run('main:app', host=os.getenv('AI_HOST','0.0.0.0'), port=int(os.getenv('AI_PORT',9000)))"]
